# ============================================================
# Verus — Landing Google Event · variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# ============================================================

# ---- HubSpot (públicos, seguros no front-end) ----
# Portal ID (Account Setup > Account Information, ou na URL do HubSpot: /contacts/<PORTAL_ID>/)
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=
# Form GUID (Marketing > Forms > [seu form] > Share/Embed)
NEXT_PUBLIC_HUBSPOT_FORM_ID=
# Região do data center HubSpot: na1 (padrão EUA) | eu1 (Europa)
NEXT_PUBLIC_HUBSPOT_REGION=na1

# URL final pública da landing (usada em canonical/OG e no gerador de QR Code)
NEXT_PUBLIC_LANDING_PAGE_URL=https://seu-dominio.com.br/verus-google-event

# Alterna entre o formulário customizado (false, padrão — visual premium)
# e o embed oficial do HubSpot (true). Veja README.
NEXT_PUBLIC_HUBSPOT_USE_EMBED=false

# Código de rastreamento HubSpot (Tracking Code). Normalmente é o mesmo Portal ID.
# Deixe vazio para desativar o tracking script.
NEXT_PUBLIC_HUBSPOT_TRACKING_ID=

# ---- HubSpot (PRIVADO — somente server-side, NUNCA prefixe com NEXT_PUBLIC) ----
# Opcional. Token de Private App, usado apenas se você quiser criar/enriquecer
# contatos diretamente via CRM API na rota /api/hubspot-lead.
# O envio padrão usa a Forms Submissions API (não precisa de token).
HUBSPOT_PRIVATE_APP_TOKEN=
